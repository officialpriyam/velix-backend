# ============================================================
# Velix Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# Server port
PORT=3005

# OpenRouter API key (required for AI code generation)
OPENROUTER_API_KEY=your_openrouter_api_key

# NVIDIA NIM API key (optional — for nvidia/* AI models)
NVIDIA_API_KEY=

# ---- Sandbox microservice ----
SANDBOX_SERVICE_URL=http://localhost:3002
SANDBOX_API_KEY=your_sandbox_api_key_here

# ---- Supabase ----
# Project URL (from Supabase Dashboard → Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co
# Anon/public key (safe for backend use, also used by AuthService)
SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (full database access — server-side only, never expose to clients)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Upstash Redis (optional — used for web search caching) ----
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# ---- Security ----
# Admin panel password (used by admin-frontend login)
ADMIN_PASSWORD=your_admin_panel_password
# API key required for /api/admin/* and admin /api/docs/* routes
# Must match ADMIN_API_KEY in admin-frontend/.env
ADMIN_API_KEY=your_admin_api_key_here
# Comma-separated admin email addresses (used by requireAdmin middleware)
ADMIN_EMAILS=admin@yourdomain.com
# Allowed CORS origins (comma-separated) — include admin-frontend if calling backend directly
CORS_ORIGINS=http://localhost:3000,http://localhost:3005,http://localhost:3010
# Session cookie max age in milliseconds (default: 7 days)
SESSION_COOKIE_MAX_AGE_MS=604800000
